{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./codegen/generated",
    "outDir": "./src/generated",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["codegen/generated/**/*.ts"],
  "exclude": ["codegen/generated/types.ts"]
}
